APP_NAME=kyrox-core
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=false
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/kyrox_core
JWT_SECRET_KEY=dev-insecure-change-me-use-env-in-production-32b
JWT_ALGORITHM=HS256
# Access JWT lifetime (days). Must match Fair CRM ACCESS_TOKEN_EXPIRE_DAYS.
ACCESS_TOKEN_EXPIRE_DAYS=15
# Refresh token + session family lifetime (days). Must be >= ACCESS_TOKEN_EXPIRE_DAYS.
REFRESH_TOKEN_EXPIRE_DAYS=15
